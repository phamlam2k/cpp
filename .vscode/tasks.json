{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build active file",
      "type": "shell",
      "command": "C:/msys64/ucrt64/bin/g++.exe",
      "args": [
        "-std=c++17",
        "-g",
        "-Wall",
        "${file}",
        "-o",
        "${fileDirname}/${fileBasenameNoExtension}.exe"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"],
      "detail": "Chi bien dich file .cpp dang mo"
    },
    {
      "label": "Build & Run (input.txt)",
      "type": "shell",
      "options": {
        "cwd": "${fileDirname}",
        "shell": {
          "executable": "C:/Program Files/Git/bin/bash.exe",
          "args": ["-c"]
        }
      },
      "command": "g++ -std=c++17 -O2 -Wall ${fileBasename} -o ${fileBasenameNoExtension}.exe && echo '=== OUTPUT ===' && ./${fileBasenameNoExtension}.exe < input.txt",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"],
      "detail": "Bien dich + chay voi input.txt trong cung thu muc (dung Git Bash)"
    },
    {
      "label": "Build & Run (nhap tay)",
      "type": "shell",
      "options": {
        "cwd": "${fileDirname}",
        "shell": {
          "executable": "C:/Program Files/Git/bin/bash.exe",
          "args": ["-c"]
        }
      },
      "command": "g++ -std=c++17 -O2 -Wall ${fileBasename} -o ${fileBasenameNoExtension}.exe && ./${fileBasenameNoExtension}.exe",
      "group": "test",
      "problemMatcher": ["$gcc"],
      "detail": "Bien dich + chay, tu go input tren terminal (dung Git Bash)"
    }
  ]
}
